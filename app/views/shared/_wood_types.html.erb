<section class="wood-types-section">
  <h2 class="wood-types-title">Dřeva v sortimentu <span class="text-blue">podle tvrdosti a barevnosti</span></h2>
  <div class="wood-types-layout">

    <div class="wood-category-box">
      <h3>Měkká</h3>
      <div class="wood-items-grid">
        <div class="wood-item">
          <%= image_tag "sortiment/palivove-drevo/smrk.png", class: "wood-texture", alt: "Smrk" %>
          <span>Smrk</span>
        </div>
        <div class="wood-item">
          <%= image_tag "sortiment/palivove-drevo/borovice.png", class: "wood-texture", alt: "Borovice" %>
          <span>Borovice</span>
        </div>
        <div class="wood-item">
          <%= image_tag "sortiment/palivove-drevo/modrin.png", class: "wood-texture", alt: "Modřín" %>
          <span>Modřín</span>
        </div>
      </div>
    </div>

    <div class="wood-category-box">
      <h3>Tvrdá</h3>
      <div class="wood-items-grid">
        <div class="wood-item">
          <%= image_tag "sortiment/palivove-drevo/buk.png", class: "wood-texture", alt: "Buk" %>
          <span>Buk</span>
        </div>
        <div class="wood-item">
          <%= image_tag "sortiment/palivove-drevo/habr.png", class: "wood-texture", alt: "Habr" %>
          <span>Habr</span>
        </div>
        <div class="wood-item">
          <%= image_tag "sortiment/palivove-drevo/dub.png", class: "wood-texture", alt: "Dub" %>
          <span>Dub</span>
        </div>
        <div class="wood-item">
          <%= image_tag "sortiment/palivove-drevo/akat.png", class: "wood-texture", alt: "Akát" %>
          <span>Akát</span>
        </div>
        <div class="wood-item">
          <%= image_tag "sortiment/palivove-drevo/jasan.png", class: "wood-texture", alt: "Jasan" %>
          <span>Jasan</span>
        </div>
      </div>
    </div>

  </div>
</section>