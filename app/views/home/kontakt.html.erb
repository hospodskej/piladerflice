              <a href="mailto:stepan.merta@seznam.cz">stepan.merta@seznam.cz</a>
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="currentColor" class="kontakt-icon"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
