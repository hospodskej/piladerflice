<header class="site-header">
  <div class="contact-header">
    <div class="contact-item">
      <svg width="14" height="14" fill="none" stroke="#30b109" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
      +420 602 446 339
    </div>
    <div class="contact-item">
      <svg width="14" height="14" fill="none" stroke="#30b109" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
      stepan.merta@seznam.cz
    </div>
  </div>
  <div class="main-nav">
    <button class="menu-toggle" id="menuToggle" aria-label="Otevřít menu">
      <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 12h18M3 6h18M3 18h18"></path></svg>
    </button>
    <div class="logo">
      <%= image_tag "logo-wm.png", alt: "Pila Derflice", class: "logo" %>
    </div>
    <nav class="nav-links desktop-nav">
      <%= link_to "Domů", root_path, class: "nav-link #{'active' if current_page?(root_path)}" %>
      <a href="#" class="nav-link">Eshop</a>
      <%= link_to "Sortiment", sortiment_path, class: "nav-link #{'active' if current_page?(sortiment_path)}" %>
      <%= link_to "Služby", sluzby_path, class: "nav-link #{'active' if current_page?(sluzby_path)}" %>
      <%= link_to "Ceník", "/kontakt#cenik", class: "nav-link", id: "nav-cenik" %>
      <%= link_to "Kontakt", kontakt_path, class: "nav-link", id: "nav-kontakt" %>
    </nav>
    <div class="lang-dropdown">
      <button class="btn-pill lang-btn">
        <svg width="20" height="15" viewBox="0 0 600 400" xmlns="http://www.w3.org/2000/svg" style="border: 1px solid #ccc; border-radius: 2px;">
          <rect width="600" height="400" fill="#d7141a"/>
          <rect width="600" height="200" fill="#fff"/>
          <polygon points="0,0 0,400 300,200" fill="#11457e"/>
        </svg>
        <span class="chevron">▼</span>
      </button>
      <div class="lang-dropdown-content">
        <a href="#" class="lang-option">
          <svg width="20" height="15" viewBox="0 0 600 400" xmlns="http://www.w3.org/2000/svg" style="border: 1px solid #ccc; border-radius: 2px;">
            <rect width="600" height="400" fill="#d7141a"/>
            <rect width="600" height="200" fill="#fff"/>
            <polygon points="0,0 0,400 300,200" fill="#11457e"/>
          </svg>
        </a>
        <a href="#" class="lang-option">
          <svg width="20" height="15" viewBox="0 0 600 400" xmlns="http://www.w3.org/2000/svg" style="border: 1px solid #ccc; border-radius: 2px;">
            <rect width="600" height="400" fill="#ed2939"/>
            <rect width="600" height="133.33" y="133.33" fill="#fff"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
  <div class="sidebar-overlay" id="sidebarOverlay"></div>
  <aside class="mobile-sidebar" id="mobileSidebar">
    <div class="sidebar-header">
      <%= image_tag "logo-wm.png", alt: "Pila Derflice", class: "sidebar-logo" %>
      <button class="close-sidebar" id="closeSidebar">✕</button>
    </div>
    <nav class="sidebar-nav">
      <%= link_to "Domů", root_path, class: "nav-link #{'active' if current_page?(root_path)}" %>
      <a href="#" class="nav-link">Eshop</a>
      <%= link_to "Sortiment", sortiment_path, class: "nav-link #{'active' if current_page?(sortiment_path)}" %>
      <%= link_to "Služby", sluzby_path, class: "nav-link #{'active' if current_page?(sluzby_path)}" %>
      <%= link_to "Ceník", "/kontakt#cenik", class: "nav-link", id: "nav-cenik" %>
      <%= link_to "Kontakt", kontakt_path, class: "nav-link", id: "nav-kontakt" %>
    </nav>
    <div class="sidebar-contact">
      <div class="contact-item">
        <svg width="18" height="18" fill="none" stroke="#30b109" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
        +420 602 446 339
      </div>
      <div class="contact-item">
        <svg width="14" height="14" fill="none" stroke="#30b109" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
        stepan.merta@seznam.cz
      </div>
    </div>
  </aside>
</header>