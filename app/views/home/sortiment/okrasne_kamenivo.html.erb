<%
  products = [
    {
      title: "Valouny a oblázky",
      descriptions: ["Dekorativní kamenivo ideální pro zahrady, chodníky, jezírka a okrasné záhony", "K dispozici v různých frakcích a barevných variantách, vhodné pro designové úpravy i praktické využití", "Nabízíme balení v pytlích nebo volně ložené dle požadavků zákazníka.", "Cena od 1kč za 1kg."],
      images: ["sortiment/kamenivo1.png"],
      eshop_link: "#"
    }
  ]
%>

<main class="main">
  <% products.each_with_index do |product, index| %>
    <%= render partial: "shared/product_row", locals: {
      title: product[:title],
      descriptions: product[:descriptions],
      images: product[:images],
      eshop_link: product[:eshop_link],
      reverse: index.odd?
    } %>
  <% end %>
  <%= render "shared/wood_types" %>
  <%= render "shared/jak_objednat" %>
</main>