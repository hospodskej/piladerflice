              <span>IČ: 45665451 | DIČ: CZ6909094742</span>
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="currentColor" class="kontakt-icon"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg>
              <span>Fakturační adresa: Meruňková 206, 671 81 Nový Šaldorf - Sedlešovice</span>
            </li>
            <li>
              <svg viewBox="0 0 24 24" fill="currentColor" class="kontakt-icon"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg>
